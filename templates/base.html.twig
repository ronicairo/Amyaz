<script defer>
    document.addEventListener("DOMContentLoaded", function (event) {

        const baseUrl = "http://127.0.0.1:8000";

        // ========================================
        // DICTIONNAIRE
        // ========================================
        const searchTypeDictionary = $("#searchType").val();
        
        if (searchTypeDictionary === "dictionary") {
            $("#lang").on('change', function () {
                suggestionsDictionary();
            });

            function suggestionsDictionary() {
                const lang = $("#lang").val();
                const q = $(".autocomplete-input").val();
                $.ajax({
                    url: baseUrl + "/traduction/autocomplete?lang=" + lang + "&q=" + q + "&searchType=dictionary",
                    dataType: "json",
                    success: function (data) {
                        initAutoCompleteDictionary(data);
                    }
                });
            }

            function initAutoCompleteDictionary(suggestionsData) {
                new autoComplete({
                    selector: ".autocomplete-input",
                    data: {
                        src: async (query) => {
                            try {
                                const lang = $("#lang").val();
                                const q = $(".autocomplete-input").val();
                                const source = await fetch(baseUrl + "/traduction/autocomplete?lang=" + lang + "&q=" + q + "&searchType=dictionary");
                                const data = await source.json();
                                return data;
                            } catch (error) {
                                console.error(error);
                                return [];
                            }
                        }
                    },
                    resultsList: {
                        maxResults: 20,
                    },
                    resultItem: {
                        highlight: true,
                        noResults: true
                    },
                    events: {
                        input: {
                            selection: (event) => {
                                const feedback = event.detail;
                                const selection = feedback.selection.value;
                                const lang = $("#lang").val();
                                document.querySelector(".autocomplete-input").value = selection;
                                window.location.replace(baseUrl + "/?lang=" + lang + "&q=" + selection);
                            }
                        }
                    }
                });
            }

            suggestionsDictionary();
        }

        // ========================================
        // VERBE
        // ========================================
        const searchTypeVerb = $("#searchTypeVerb").val();

        if (searchTypeVerb === "verb") {
            $("#langVerb").on('change', function () {
                suggestionsVerb();
            });

            function suggestionsVerb() {
                const lang = $("#langVerb").val();
                const q = $(".autocomplete-input-verb").val();
                $.ajax({
                    url: baseUrl + "/traduction/autocomplete?lang=" + lang + "&q=" + q + "&searchType=verb",
                    dataType: "json",
                    success: function (data) {
                        initAutoCompleteVerb(data);
                    }
                });
            }

            function initAutoCompleteVerb(suggestionsData) {
                new autoComplete({
                    selector: ".autocomplete-input-verb",
                    data: {
                        src: async (query) => {
                            try {
                                const lang = $("#langVerb").val();
                                const q = $(".autocomplete-input-verb").val();
                                const source = await fetch(baseUrl + "/traduction/autocomplete?lang=" + lang + "&q=" + q + "&searchType=verb");
                                const data = await source.json();
                                return data;
                            } catch (error) {
                                console.error(error);
                                return [];
                            }
                        }
                    },
                    resultsList: {
                        maxResults: 20,
                    },
                    resultItem: {
                        highlight: true,
                        noResults: true
                    },
                    events: {
                        input: {
                            selection: (event) => {
                                const feedback = event.detail;
                                const selection = feedback.selection.value;
                                const lang = $("#langVerb").val();
                                document.querySelector(".autocomplete-input-verb").value = selection;
                                window.location.replace(baseUrl + "/verbe?lang=" + lang + "&terme=" + selection);
                            }
                        }
                    }
                });
            }

            suggestionsVerb();

            // BLOQUER ENTRÉE SUR VERBE
            $(".autocomplete-input-verb").on("keydown", function(e) {
                if (e.key === "Enter" || e.keyCode === 13) {
                    e.preventDefault();
                    e.stopPropagation();
                    return false;
                }
            });

            $("#searchFormVerb").on("submit", function(e) {
                e.preventDefault();
                e.stopPropagation();
                return false;
            });
        }

        // ========================================
        // CLAVIER RIFAIN - DICTIONNAIRE
        // ========================================
        const toggleKeyboard = document.getElementById("toggle-keyboard");
        const rifainChars = document.getElementById("rifain-characters");
        const searchInput = document.getElementById("search-input");
        const langSelect = document.getElementById("lang");

        if (toggleKeyboard && rifainChars && searchInput) {
            toggleKeyboard.addEventListener("click", function () {
                rifainChars.style.display = (rifainChars.style.display === "none" || rifainChars.style.display === "") ? "flex" : "none";
            });

            rifainChars.addEventListener("click", function (e) {
                if (e.target.tagName === "SPAN") {
                    const char = e.target.textContent;
                    const startPos = searchInput.selectionStart;
                    const endPos = searchInput.selectionEnd;
                    searchInput.value = searchInput.value.substring(0, startPos) + char + searchInput.value.substring(endPos);
                    searchInput.setSelectionRange(startPos + 1, startPos + 1);
                    searchInput.focus();
                    searchInput.dispatchEvent(new Event('input', { bubbles: true }));
                    rifainChars.style.display = "none";
                }
            });

            if (langSelect) {
                langSelect.addEventListener("change", function () {
                    const lang = langSelect.value;
                    toggleKeyboard.style.display = (lang === "rif-en" || lang === "rif-fr") ? "flex" : "none";
                    if (lang !== "rif-en" && lang !== "rif-fr") rifainChars.style.display = "none";
                });
                toggleKeyboard.style.display = (langSelect.value === "rif-en" || langSelect.value === "rif-fr") ? "flex" : "none";
            }
        }

        // ========================================
        // CLAVIER RIFAIN - VERBE
        // ========================================
        const toggleKeyboardVerb = document.getElementById("toggle-keyboard-verb");
        const rifainCharsVerb = document.getElementById("rifain-characters-verb");
        const searchInputVerb = document.getElementById("search-input-verb");
        const langSelectVerb = document.getElementById("langVerb");

        if (toggleKeyboardVerb && rifainCharsVerb && searchInputVerb) {
            toggleKeyboardVerb.addEventListener("click", function () {
                rifainCharsVerb.style.display = (rifainCharsVerb.style.display === "none" || rifainCharsVerb.style.display === "") ? "flex" : "none";
            });

            rifainCharsVerb.addEventListener("click", function (e) {
                if (e.target.tagName === "SPAN") {
                    const char = e.target.textContent;
                    const startPos = searchInputVerb.selectionStart;
                    const endPos = searchInputVerb.selectionEnd;
                    searchInputVerb.value = searchInputVerb.value.substring(0, startPos) + char + searchInputVerb.value.substring(endPos);
                    searchInputVerb.setSelectionRange(startPos + 1, startPos + 1);
                    searchInputVerb.focus();
                    searchInputVerb.dispatchEvent(new Event('input', { bubbles: true }));
                    rifainCharsVerb.style.display = "none";
                }
            });

            if (langSelectVerb) {
                langSelectVerb.addEventListener("change", function () {
                    const lang = langSelectVerb.value;
                    toggleKeyboardVerb.style.display = (lang === "rif-en" || lang === "rif-fr") ? "flex" : "none";
                    if (lang !== "rif-en" && lang !== "rif-fr") rifainCharsVerb.style.display = "none";
                });
                toggleKeyboardVerb.style.display = (langSelectVerb.value === "rif-en" || langSelectVerb.value === "rif-fr") ? "flex" : "none";
            }
        }

    });
</script>

<script src="https://cdn.jsdelivr.net/npm/lamejs@1.2.0/lame.min.js"></script>


<script>

    $(document).ready(function() {
        isRecording = false;
        $('#startRiffianSingularBtn, #startRiffianPluralBtn').on('click', function() {

            if($(this).is('[disabled]')){
                showToast("Terminez l'enregistrement en cours !");
                return;
            }
            $(this).toggleClass('text-white');
            $(this).toggleClass('text-danger');



            if (isRecording) {
                let noRecordContainer = $(this).closest('.recordLang').find('.no-record');
                noRecordContainer.find(".record-deleted").val(false);
                stopRecording($(this));  // Stop the recording
            } else {
                $('#startRiffianSingularBtn, #startRiffianPluralBtn').attr('disabled','disabled');
                $(this).removeAttr('disabled');
                startRecording();  // Start the recroding
            }
            isRecording = !isRecording;  // Toggle recording state
        });

        $('#deleteRiffianSingularBtn, #deleteRiffianPluralBtn').on('click', function() {
            let audioContainer = $(this).closest('.recordLang').find('.audio-container');
            let noRecordContainer = $(this).closest('.recordLang').find('.no-record');

            noRecordContainer.find(".record-deleted").val(true);
            audioContainer.addClass('d-none');
            noRecordContainer.removeClass('d-none');
        });

        const preloadedAudios = {}; // Store preloaded audio objects

        // Preload all audio files on page load
        $('.audio-trigger').each(function () {
            const $trigger = $(this);
            const audioUrl = $trigger.data('audio-url'); // Get the audio URL from the data attribute

            // Preload the audio blob
            const audio = new Audio(audioUrl);
            audio.preload = 'auto'; // Set preload mode to 'auto'
            preloadedAudios[audioUrl] = audio; // Store the preloaded audio object
        });

        // Play preloaded audio on click
        $('.audio-trigger').on('click', function (e) {
            e.preventDefault();

            const $trigger = $(this);
            const audioUrl = $trigger.data('audio-url');
            const audio = preloadedAudios[audioUrl];

            if (audio) {
                if (audio.paused) {
                    audio.play();
                } else {
                    audio.pause();
                }
            }
        });
    });


    let mediaRecorder;
    let audioChunks = [];
    let currentRecordingType = '';

    function startRecording() {

        console.log('start recording');

        navigator.mediaDevices.getUserMedia({ audio: true })
            .then(stream => {
                mediaRecorder = new MediaRecorder(stream,{ mimeType: 'audio/mp4' });
                mediaRecorder.start();
                audioChunks = [];

                mediaRecorder.ondataavailable = event => {
                    audioChunks.push(event.data);
                };

            })
            .catch(error => {
                console.error("Error accessing microphone:", error);
            });
    }

    function stopRecording(element) {
        if (mediaRecorder) {
            mediaRecorder.stop();

            mediaRecorder.onstop = async () => {

                $('#startRiffianSingularBtn, #startRiffianPluralBtn').removeAttr('disabled');


                const audioBlob = new Blob(audioChunks, { type: 'audio/mp4' });


                audioElement = element.closest('.recordLang').find('audio source');
                let audioContainer = element.closest('.recordLang').find('.audio-container');
                let audioTag = element.closest('.recordLang').find('audio');
                let noRecordContainer = element.closest('.recordLang').find('.no-record');

                audioContainer.removeClass('d-none');
                noRecordContainer.addClass('d-none');


                const audioURL = URL.createObjectURL(audioBlob);
                audioElement.attr('src', audioURL);
                audioTag[0].load();


                const file = new File([audioBlob], 'recording.wav', { type: 'audio/mp4' });

                // Attach the file to the file input using jQuery
                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(file);
                audioContainer.find('.recorder')[0].files = dataTransfer.files;

            };

        }
    }

    function showToast(message) {
        // Create the toast element
        const toast = $('<div></div>')
            .text(message)
            .css({
                position: 'fixed',
                bottom: '30px',
                left: '50%',
                transform: 'translateX(-50%)',
                backgroundColor: '#333',
                color: '#fff',
                padding: '16px',
                borderRadius: '5px',
                fontSize: '17px',
                zIndex: 1000,
                opacity: 0,
                transition: 'opacity 0.5s',
            })
            .appendTo('body');

        // Show the toast with a fade-in effect
        setTimeout(() => {
            toast.css('opacity', 1);
        }, 100);

        // Hide and remove the toast after 3 seconds
        setTimeout(() => {
            toast.css('opacity', 0);
            setTimeout(() => {
                toast.remove();
            }, 500);
        }, 3000);
    }




</script>

</body>
